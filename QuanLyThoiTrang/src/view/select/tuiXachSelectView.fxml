<?import javafx.scene.layout.AnchorPane?>

<AnchorPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="control.selectControl.tuiXachSelectControl">
   <children>
      <ChoiceBox fx:id="myChoiceBox" layoutY="1.0" prefWidth="150.0" />
      <Button fx:id="myButton" layoutX="225.0" layoutY="1.0" mnemonicParsing="false" onAction="#clickButton" text="select" />
   </children>
</AnchorPane>
